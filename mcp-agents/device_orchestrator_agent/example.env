# PostgreSQL — can share the same DB as other agents
POSTGRES_USER=health_user
POSTGRES_PASSWORD=health_pass
POSTGRES_DB=health_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Downstream MCP agent URLs
OURA_RING_AGENT_URL=http://localhost:6330/mcp
APPLE_HEALTH_AGENT_URL=http://localhost:6331/mcp

# Polling interval in seconds (default: 600 = 10 minutes)
POLL_INTERVAL_SECONDS=600

# MCP server
MCP_HOST=0.0.0.0
MCP_PORT=6340
